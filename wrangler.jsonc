{
  // Worker Cloudflare du bot (PLAN.md E6 ; architecture : SPIKE-HOSTING.md §4)
  "name": "bookmark-reminder",
  "main": "worker/index.ts",
  "compatibility_date": "2026-05-01",
  "triggers": {
    // Double cron UTC : 8h30 Europe/Paris été (UTC+2) et hiver (UTC+1).
    // La garde isLocalTime (src/schedule.ts) ignore la mauvaise branche.
    // ⚠️ Couplé à DIGEST_PARIS_TIME : changer l'heure du digest exige
    // d'aligner les DEUX crons (mêmes minutes), sinon plus aucune branche
    // ne matche et le digest est silencieusement désactivé.
    "crons": ["30 6 * * *", "30 7 * * *"]
  },
  "durable_objects": {
    "bindings": [{ "name": "BOT_DO", "class_name": "BotDO" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["BotDO"] }],
  "vars": {
    "DIGEST_PARIS_TIME": "08:30",
    "TWEET_LINK_DOMAIN": "x.com",
    "MAX_RESULTS": "25",
    // Modèle Claude du résumé IA (PLAN-IA-DIGEST.md §3) ; alternatives moins
    // chères : claude-sonnet-4-6, claude-haiku-4-5. Sans effet tant que le
    // secret ANTHROPIC_API_KEY n'est pas posé.
    "ANTHROPIC_MODEL": "claude-opus-4-8",
    // URL publique du Worker (connue après le 1er deploy) : sert au lien de
    // re-auth dans les alertes Telegram. À renseigner avec VOTRE URL
    // https://bookmark-reminder.<sous-domaine>.workers.dev (vide = hint générique).
    "BASE_URL": "",
    // « on » pendant la bascule local→cloud uniquement (routes /admin/*) ;
    // repasser à « off » + redéployer une fois la bascule terminée.
    "ADMIN_API": "off"
  },
  "observability": { "enabled": true }
  // Secrets à poser via `npx wrangler secret put <NOM>` :
  //   X_CLIENT_ID, X_CLIENT_SECRET (si client confidentiel),
  //   TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID, AUTH_URL_KEY,
  //   ANTHROPIC_API_KEY (optionnel — résumé IA ; absent = bot inchangé)
}
