# App X (developer.x.com) — OAuth 2.0 activé, type Web App / Public client,
# callback : http://127.0.0.1:8765/callback (bien 127.0.0.1, pas localhost)
X_CLIENT_ID=
# Uniquement si l'app X est un client confidentiel (sinon laisser vide) :
X_CLIENT_SECRET=

# Bot Telegram (@BotFather → /newbot), puis chat id via
# https://api.telegram.org/bot<TOKEN>/getUpdates après avoir écrit au bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optionnel
# MAX_RESULTS=25            # posts par endpoint et par run (5-100 ; l'API likes refuse < 5)
# TWEET_LINK_DOMAIN=x.com   # fallback aperçus : fixupx.com
