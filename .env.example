# X App (developer.x.com) — OAuth 2.0 enabled, type Web App / Public client,
# callback: http://127.0.0.1:8765/callback (make sure it's 127.0.0.1, not localhost)
X_CLIENT_ID=
# Only if the X app is a confidential client (otherwise leave empty):
X_CLIENT_SECRET=

# Telegram bot (@BotFather → /newbot), then chat id via
# https://api.telegram.org/bot<TOKEN>/getUpdates after messaging the bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional
# MAX_RESULTS=25            # posts per endpoint and per run (5-100; the likes API refuses < 5)
# TWEET_LINK_DOMAIN=x.com   # previews fallback: fixupx.com
# ANTHROPIC_API_KEY=        # enables the AI digest summary (absent = bot unchanged)
# ANTHROPIC_MODEL=claude-opus-4-8  # or claude-sonnet-4-6 / claude-haiku-4-5 (cheaper)
